    {
      "parameters": {},
      "id": "da75ec67-57ea-4c1d-a345-1cb3b7c8f767",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        -900,
        128
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body ?? input;\nconst feedback = body.feedback ?? body;\nif (!feedback.output_id) {\n  feedback.output_id = 'out-' + new Date().toISOString().slice(0, 10) + '-manual-feedback';\n}\nif (!feedback.decision) {\n  feedback.decision = 'output_only';\n}\nif (!Array.isArray(feedback.candidate_items)) {\n  feedback.candidate_items = [];\n}\nconst approved = body.approved === true || feedback.approved === true || body.approved === 'true' || feedback.approved === 'true';\nif (feedback.decision === 'propagate' && !approved) {\n  throw new Error('Human approval required: send approved=true with propagate feedback before applying wiki changes.');\n}\ndelete feedback.approved;\nreturn [{\n  json: {\n    approved,\n    feedback,\n    payload_b64: Buffer.from(JSON.stringify(feedback), 'utf8').toString('base64')\n  }\n}];"
      },
      "id": "b448c3d3-9d3d-4636-8b77-2fb8856db7de",
      "name": "Prepare Feedback Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -560,
        16
      ],
      "notesInFlow": true,
      "notes": "Accepts either the Feedback Record directly or a top-level field named feedback. Propagation requires approved=true."
    },
    {
      "parameters": {
        "command": "={{ \"node -e \" + JSON.stringify(\"process.stdout.write(Buffer.from(process.argv[1], 'base64').toString('utf8'))\") + \" \" + JSON.stringify($json.payload_b64) + \" | npm --silent --prefix /app run feedback-record -- --vault /data/vault\" }}",
        "executeOnce": true
      },
      "id": "26d3e5da-76bd-48d8-b131-b0a205ad7ca0",
      "name": "Run feedback-record.ts",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        -200,
        16
      ]
    },
    {
      "parameters": {
        "jsCode": "const stdout = $input.first().json.stdout ?? '';\nif (!stdout.trim()) {\n  throw new Error('feedback-record.ts returned empty stdout');\n}\nreturn [{ json: JSON.parse(stdout) }];"
      },
      "id": "64b59243-8557-407b-9749-e7e34f3477c2",
      "name": "Parse Feedback Result",
      "type": "n8n-nodes-base.code",
