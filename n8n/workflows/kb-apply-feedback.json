      "parameters": {
        "jsCode": "return [{\n  json: {\n    status: 'feedback_propagated',\n    feedback_record: $node[\"Parse Feedback Result\"].json.record,\n    feedback_record_path: $node[\"Parse Feedback Result\"].json.record_path,\n    mutation_plan_path: $node[\"Parse Feedback Result\"].json.mutation_plan_path,\n    mutation_result: $node[\"Parse Mutation Result\"].json,\n    reindex_result: $node[\"Parse Reindex Result\"].json,\n    commit_result: $node[\"Parse Commit Result\"].json\n  }\n}];"
      },
