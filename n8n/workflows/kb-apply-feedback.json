        "jsCode": "const stdout = $input.first().json.stdout ?? '';\nif (!stdout.trim()) {\n  throw new Error('reindex.ts returned empty stdout');\n}\nreturn [{ json: JSON.parse(stdout) }];"
      },
      "id": "e8fccdd9-08b7-4b29-a255-d31934be61f3",
      "name": "Parse Reindex Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1420,
        -112
      ]
    },
    {
      "parameters": {
        "jsCode": "const feedback = $node[\"Parse Feedback Result\"].json;\nconst mutation = $node[\"Parse Mutation Result\"].json;\nconst payload = {\n  operation: 'feedback',\n  summary: `Propagate feedback for ${feedback.record.output_id}`,\n  source_refs: feedback.record.source_refs ?? [],\n  affected_notes: feedback.record.affected_notes ?? [],\n  paths_to_stage: [\n    feedback.record_path,\n    feedback.summary_path,\n    ...(feedback.mutation_plan_path ? [feedback.mutation_plan_path] : []),\n    ...mutation.created,\n    ...mutation.updated,\n    'state/runtime/idempotency-keys.json'\n  ],\n  feedback_record_ref: feedback.record_path,\n  commit_message: `feedback: ${feedback.record.output_id}`\n};\nreturn [{\n  json: {\n    payload,\n    payload_b64: Buffer.from(JSON.stringify(payload), 'utf8').toString('base64')\n  }\n}];"
      },
      "id": "8ed5395a-6207-403a-a72e-3e2ba16f3f1a",
      "name": "Build Commit Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1680,
        -112
      ]
    },
