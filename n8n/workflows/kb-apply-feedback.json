        "command": "={{ \"npm --silent --prefix /app run apply-update -- --vault /data/vault --input /data/vault/\" + $node[\"Parse Feedback Result\"].json[\"mutation_plan_path\"] }}",
        "executeOnce": true
      },
      "id": "6f0eb6f6-07d2-4f3e-9314-f25c72689685",
