        "command": "={{ \"node -e \" + JSON.stringify(\"process.stdout.write(Buffer.from(process.argv[1], 'base64').toString('utf8'))\") + \" \" + JSON.stringify($json.payload_b64) + \" | npm --silent --prefix /app run commit -- --vault /data/vault\" }}",
        "executeOnce": true
      },
      "id": "1aa7ee27-d4db-49f5-b0f6-85b0aee8e235",
      "name": "Run commit.ts",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
