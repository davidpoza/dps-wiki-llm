        "jsCode": "const stdout = $input.first().json.stdout ?? '';\nif (!stdout.trim()) {\n  throw new Error('commit.ts returned empty stdout');\n}\nreturn [{ json: JSON.parse(stdout) }];"
      },
      "id": "1be66d7c-d5d9-41fe-9210-916f5c99c9c8",
      "name": "Parse Commit Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
