      ]
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    status: 'feedback_recorded',\n    decision: $node[\"Parse Feedback Result\"].json.record.decision,\n    feedback_record: $node[\"Parse Feedback Result\"].json.record,\n    feedback_record_path: $node[\"Parse Feedback Result\"].json.record_path,\n    summary_path: $node[\"Parse Feedback Result\"].json.summary_path,\n    mutation_plan_path: $node[\"Parse Feedback Result\"].json.mutation_plan_path\n  }\n}];"
      },
      "id": "6a3a9600-3122-47c9-9be1-a3468c00aee1",
      "name": "Build No-Propagation Response",
      "type": "n8n-nodes-base.code",
