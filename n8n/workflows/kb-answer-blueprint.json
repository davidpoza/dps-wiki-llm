      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -1080,
        80
      ],
      "notesInFlow": true,
      "notes": "Polls Telegram once per minute. getUpdates does not require public inbound access to n8n."
    },
    {
      "parameters": {
        "jsCode": "const env = typeof $env !== 'undefined' ? $env : (globalThis.process?.env ?? {});\nconst token = String(env.TELEGRAM_BOT_TOKEN ?? '').trim();\nconst staticData = typeof $getWorkflowStaticData === 'function' ? $getWorkflowStaticData('global') : {};\nconst lastUpdateId = Number(staticData.telegram_last_update_id);\nconst request = { limit: 1, timeout: 0, allowed_updates: ['message', 'edited_message'] };\nif (Number.isSafeInteger(lastUpdateId) && lastUpdateId >= 0) {\n  request.offset = lastUpdateId + 1;\n} else {\n  request.offset = -1;\n}\nreturn [{ json: { telegram_poll_enabled: Boolean(token), telegram_skip_reason: token ? null : 'Missing Telegram runtime configuration: TELEGRAM_BOT_TOKEN', telegram_bot_token: token, telegram_poll_request: request, telegram_first_poll_drops_backlog: request.offset === -1 } }];"
      },
      "id": "telegram-build-poll",
      "name": "Build Telegram Poll Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -780,
