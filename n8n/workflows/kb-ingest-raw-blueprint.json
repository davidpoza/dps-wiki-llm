    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst body = input.body ?? input;\nconst detectedPath = body.raw_path || body.path || body.filePath || body.filename || 'raw/inbox/example.md';\nconst normalized = {\n  raw_path: detectedPath,\n  trigger_source: body.path || body.filePath || body.filename ? 'local-file-trigger' : 'manual',\n  captured_at: body.captured_at || new Date().toISOString()\n};\nreturn [{ json: normalized }];"
      },
      "id": "16635cb1-fc84-42dc-ba91-f5f5f996e0f3",
