    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    plan_input_path: '/data/vault/state/tmp/ingest-plan.json',\n    commit_input_path: '/data/vault/state/tmp/ingest-commit.json',\n    note: 'Replace this node with ingest-source.mjs plus your LLM planner. Downstream nodes assume a valid Mutation Plan JSON file exists at plan_input_path.'\n  }\n}];"
