    {
      "parameters": {
        "jsCode": "const payload = $input.first().json;\nreturn [{\n  json: {\n    payload,\n    payload_b64: Buffer.from(JSON.stringify(payload), 'utf8').toString('base64')\n  }\n}];"
      },
      "id": "328e079d-24c2-4044-b3f5-9d8b242cb433",
