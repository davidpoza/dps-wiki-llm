        "jsCode": "const stdout = $input.first().json.stdout ?? '';\nif (!stdout.trim()) {\n  throw new Error('ingest-source.ts returned empty stdout');\n}\nconst source_payload = JSON.parse(stdout);\nreturn [{\n  json: {\n    source_payload,\n    payload_b64: Buffer.from(JSON.stringify(source_payload), 'utf8').toString('base64')\n  }\n}];"
