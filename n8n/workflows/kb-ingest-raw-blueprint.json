        "jsCode": "const input = $input.first().json;\nconst detectedPath = input.path || input.filePath || input.filename || 'raw/inbox/example.md';\nconst normalized = {\n  raw_path: detectedPath,\n  trigger_source: input.path ? 'local-file-trigger' : 'manual',\n  source_kind: detectedPath.includes('/voice/') ? 'voice' : detectedPath.includes('/bookmarks/') ? 'bookmark' : detectedPath.includes('/web/') ? 'web' : 'note'\n};\nreturn [{ json: normalized }];"
      },
      "id": "16635cb1-fc84-42dc-ba91-f5f5f996e0f3",
