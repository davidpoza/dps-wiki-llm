      "notesInFlow": true,
      "notes": "Deterministic baseline planner: creates the source note and root index update. Replace this node with your provider-specific LLM planner when you want concept/entity/topic updates in the same ingest run."
    },
    {
      "parameters": {
        "jsCode": "const stdout = $input.first().json.stdout ?? '';\nif (!stdout.trim()) {\n  throw new Error('plan-source-note.ts returned empty stdout');\n}\nconst parsed = JSON.parse(stdout);\nif (!parsed.mutation_plan || !parsed.commit_input) {\n  throw new Error('plan-source-note.ts must return mutation_plan and commit_input');\n}\nreturn [{\n  json: {\n    source_payload: parsed.source_payload,\n    mutation_plan: parsed.mutation_plan,\n    commit_input: parsed.commit_input,\n    plan_b64: Buffer.from(JSON.stringify(parsed.mutation_plan), 'utf8').toString('base64'),\n    commit_b64: Buffer.from(JSON.stringify(parsed.commit_input), 'utf8').toString('base64')\n  }\n}];"
      },
