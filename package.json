{
  "name": "dps-wiki-llm",
  "private": true,
  "version": "0.1.0",
  "description": "Deterministic Node.js tooling for a persistent wiki knowledge system.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test",
    "test:coverage": "npm run build && node --test --experimental-test-coverage",
    "init-db": "node dist/tools/cmd/init-db.js",
    "ingest-source": "node dist/tools/cmd/ingest-source.js",
    "youtube-transcript": "node dist/tools/cmd/youtube-transcript.js",
    "pdf-extract": "node dist/tools/cmd/pdf-extract.js",
    "bot-lock": "node dist/tools/cmd/bot-lock.js",
    "render-n8n-workflows": "node dist/tools/cmd/render-n8n-workflows.js",
    "ingest-run": "node dist/tools/cmd/ingest-run.js",
    "answer-run": "node dist/tools/cmd/answer-run.js",
    "search-run": "node dist/tools/cmd/search-run.js",
    "plan-source-note": "node dist/tools/cmd/plan-source-note.js",
    "apply-update": "node dist/tools/cmd/apply-update.js",
    "answer-context": "node dist/tools/cmd/answer-context.js",
    "answer-record": "node dist/tools/cmd/answer-record.js",
    "feedback-record": "node dist/tools/cmd/feedback-record.js",
    "reindex": "node dist/tools/cmd/reindex.js",
    "search": "node dist/tools/cmd/search.js",
    "lint": "node dist/tools/cmd/lint.js",
    "health-check": "node dist/tools/cmd/health-check.js",
    "commit": "node dist/tools/cmd/commit.js",
    "log-tail": "node dist/tools/cmd/log-tail.js",
    "embed-index": "node dist/tools/cmd/embed-index.js",
    "semantic-search": "node dist/tools/cmd/semantic-search.js",
    "hybrid-search": "node dist/tools/cmd/hybrid-search.js",
    "enrich-links": "node dist/tools/cmd/enrich-links.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opendocsg/pdf2md": "^0.2.6",
    "@xenova/transformers": "^2.17.2",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0"
  }
}
