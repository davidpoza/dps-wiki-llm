# Copy this file to .env and fill the secrets before running Docker Compose.
# Do not commit .env.

# n8n public runtime
DOMAIN_NAME=n8n.example.com
GENERIC_TIMEZONE=Europe/Madrid
N8N_VERSION=latest

# n8n basic auth
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# n8n external task runner
RUNNERS_AUTH_TOKEN=change-me-to-a-long-random-token
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Postgres bootstrap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=n8n
POSTGRES_NON_ROOT_USER=n8n
POSTGRES_NON_ROOT_PASSWORD=change-me

# Vault location for examples that mount an absolute host path.
# The README compose example uses ./local-files directly.
DPS_WIKI_VAULT_PATH=./local-files

# Git identity used by commit.ts inside Docker/n8n.
GIT_AUTHOR_NAME=DPS Wiki Bot
GIT_AUTHOR_EMAIL=dps-wiki-bot@example.local
GIT_COMMITTER_NAME=DPS Wiki Bot
GIT_COMMITTER_EMAIL=dps-wiki-bot@example.local

# LLM runtime
LLM_API_KEY=change-me
# Used at runtime by answer-run.ts and ingest-run.ts. Defaults to Authorization.
LLM_API_KEY_HEADER=Authorization
LLM_BASE_URL=https://llm.example.test/v1
LLM_MODEL=example/model
LLM_ANSWER_TEMPERATURE=0.2

# Embedding model (used by embed-index.ts for semantic search and cosim)
# Any Xenova/transformers.js-compatible sentence-transformer model.
# Default: Xenova/multilingual-e5-small
# Example (higher quality, slower): Xenova/bge-m3
EMBED_MODEL=Xenova/multilingual-e5-small

# Node.js heap limit for embed-index (MB). Increase if /embedindex is killed by OOM.
# multilingual-e5-small: 1024 MB is typically sufficient.
# bge-m3: 3072–4096 MB recommended.
EMBED_MAX_OLD_SPACE_MB=3072

# Logging
# Controls the minimum log level written to state/logs/app.log.
# Accepted values (pino): trace | debug | info | warn | error | fatal
# Default: info — set to debug to capture full LLM prompt and response payloads.
LOG_LEVEL=info

# Telegram Bot API
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_CHAT_ID=change-me
TELEGRAM_BOT_LOCK_TTL_MS=1800000
