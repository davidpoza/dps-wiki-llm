# syntax=docker/dockerfile:1.7

ARG NODE_IMAGE=node:22-alpine
ARG N8N_RUNNERS_IMAGE=n8nio/runners:latest

FROM ${NODE_IMAGE} AS kb-build

WORKDIR /app

COPY package.json package-lock.json tsconfig.json ./
COPY tools ./tools

RUN npm ci && npm run build && npm prune --omit=dev

FROM ${N8N_RUNNERS_IMAGE} AS runtime

USER root

RUN set -eux; \
  if command -v python3 >/dev/null 2>&1 && python3 -m pip --version >/dev/null 2>&1; then \
    python3 -m pip install --no-cache-dir --break-system-packages yt-dlp || python3 -m pip install --no-cache-dir yt-dlp; \
  elif command -v apk >/dev/null 2>&1; then \
    apk add --no-cache ca-certificates python3 py3-pip gcompat; \
    python3 -m pip install --no-cache-dir --break-system-packages yt-dlp; \
  elif command -v apt-get >/dev/null 2>&1; then \
    apt-get update; \
    apt-get install -y --no-install-recommends ca-certificates python3 python3-pip; \
    python3 -m pip install --no-cache-dir --break-system-packages yt-dlp; \
    rm -rf /var/lib/apt/lists/*; \
  else \
    echo "Unsupported runner base image: missing python3/pip, apk, and apt-get" >&2; \
    exit 1; \
  fi; \
  yt-dlp --version; \
  cd /opt/runners/task-runner-javascript; \
  pnpm add axios qs

WORKDIR /app

COPY --from=kb-build --chown=runner:runner /app/package.json ./package.json
COPY --from=kb-build --chown=runner:runner /app/node_modules ./node_modules
COPY --from=kb-build --chown=runner:runner /app/dist ./dist
COPY --chown=runner:runner docker/n8n-task-runners.json /etc/n8n-task-runners.json

RUN set -eux; \
  node -e "const [major, minor] = process.versions.node.split('.').map(Number); if (major < 22 || (major === 22 && minor < 5)) { throw new Error('dps-wiki-llm requires Node.js >=22.5.0; runner image has ' + process.versions.node); }"; \
  node -e "require('node:sqlite')"; \
  test -f /app/dist/tools/search.js; \
  yt-dlp --version; \
  cd /opt/runners/task-runner-javascript; \
  node -e "Promise.all([import('axios'), import('qs')])"

USER runner
WORKDIR /home/runner
